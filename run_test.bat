@echo off
:: Переходим в папку с проектом (замени путь на свой, если он другой)
cd /d "%~dp0"

:: Запускаем сервер в фоновом режиме
start /b uvicorn main:app --host 127.0.0.1 --port 8000

:: Ждем 2 секунды, чтобы сервер успел подняться
timeout /t 2 /nobreak > nul

:: Открываем браузер со страницей теста
start http://127.0.0.1:8000/static/index.html

echo Тест запущен! Не закрывай это окно, пока проходишь тест.
pause